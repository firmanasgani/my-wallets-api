generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String   @id @default(uuid())
  username       String   @unique
  email          String   @unique
  passwordHash   String   @unique
  fullName       String?
  profilePicture String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  resetPasswordOtp          String?
  resetPasswordOtpExpires   DateTime?
  resetPasswordToken        String?
  resetPasswordTokenExpires DateTime?

  accounts              Account[]
  categories            Category[]
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  logs                  Log[]
  budgets               Budget[]
  subscriptions         UserSubscription[]
  paymentTransactions   PaymentTransaction[]
  FinancialGoals        FinancialGoal[]

  // Business relations
  ownedCompany                 Company?                 @relation("CompanyOwner")
  companyMembers               CompanyMember[]
  createdInvoices              Invoice[]
  createdJournalEntries        JournalEntry[]           @relation("JournalCreator")
  checkedJournalEntries        JournalEntry[]           @relation("JournalChecker")
  approvedJournalEntries       JournalEntry[]           @relation("JournalApprover")
  invoiceAttachments           InvoiceAttachment[]      @relation("InvoiceAttachments")
  journalEntryAttachments      JournalEntryAttachment[] @relation("JournalEntryUploads")
  createdAssets                Asset[]
}

model SubscriptionPlan {
  id             String   @id @default(uuid())
  name           String   @unique
  code           String   @unique // FREE, PREMIUM_1M, PREMIUM_6M, PREMIUM_1Y
  description    String?
  price          Decimal  @db.Decimal(18, 2)
  discountPrice  Decimal? @db.Decimal(18, 2)
  durationMonths Int? // Number of months
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userSubscriptions   UserSubscription[]
  paymentTransactions PaymentTransaction[]
}

model UserSubscription {
  id                 String             @id @default(uuid())
  userId             String
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionPlanId String
  plan               SubscriptionPlan   @relation(fields: [subscriptionPlanId], references: [id])
  startDate          DateTime           @default(now())
  endDate            DateTime?
  status             SubscriptionStatus @default(ACTIVE)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@index([userId, status])
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum AccountType {
  BANK
  E_WALLET
  CASH
  CREDIT_CARD
}

model Bank {
  id        String   @id @default(uuid())
  name      String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  accounts Account[]
}

model Account {
  id             String      @id @default(uuid())
  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountName    String
  accountType    AccountType
  initialBalance Decimal     @default(0) @db.Decimal(18, 2)
  currentBalance Decimal     @default(0) @db.Decimal(18, 2)
  currency       String      @default("IDR")
  accountNumber  String?
  bankId         String?
  bank           Bank?       @relation(fields: [bankId], references: [id], onDelete: SetNull)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  transactionsAsSource      Transaction[] @relation("SourceTransactions")
  transactionsAsDestination Transaction[] @relation("DestinationTransactions")
  goalLedgers               GoalLedger[]

  recurringTransactionsAsSource      RecurringTransaction[] @relation("SourceRecurringTransactions")
  recurringTransactionsAsDestination RecurringTransaction[] @relation("DestinationRecurringTransactions")
}

enum CategoryType {
  INCOME
  EXPENSE
}

model Category {
  id                    String                 @id @default(uuid())
  userId                String
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryName          String
  categoryType          CategoryType
  parentCategoryId      String?
  parentCategory        Category?              @relation("SubCategories", fields: [parentCategoryId], references: [id])
  subCategories         Category[]             @relation("SubCategories")
  icon                  String?
  color                 String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  transactions          Transaction[]
  recurringTransactions RecurringTransaction[]
  budgets               Budget[]

  @@unique([userId, categoryName, categoryType, parentCategoryId])
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
}

enum RecurringInterval {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurringStatus {
  ACTIVE
  INACTIVE
}

model Transaction {
  id                   String          @id @default(uuid())
  userId               String
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionType      TransactionType
  amount               Decimal         @db.Decimal(18, 2)
  transactionDate      DateTime        @default(now())
  description          String?
  categoryId           String?
  category             Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sourceAccountid      String?
  sourceAccount        Account?        @relation("SourceTransactions", fields: [sourceAccountid], references: [id], onDelete: SetNull)
  destinationAccountId String?
  destinationAccount   Account?        @relation("DestinationTransactions", fields: [destinationAccountId], references: [id], onDelete: SetNull)
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt

  recurringTransactionId String?
  recurringTransaction   RecurringTransaction? @relation(fields: [recurringTransactionId], references: [id], onDelete: SetNull)
  attachmentPath         String?
  goalLedgers            GoalLedger[]

  @@index([userId, transactionType, transactionDate])
  @@index([userId, categoryId])
}

enum LogActionType {
  USER_REGISTER
  USER_LOGIN
  USER_LOGOUT
  USER_DELETE
  USER_PROFILE_UPDATE
  ACCOUNT_CREATE
  ACCOUNT_UPDATE
  ACCOUNT_DELETE
  CATEGORY_CREATE
  CATEGORY_UPDATE
  CATEGORY_DELETE
  TRANSACTION_CREATE_INCOME
  TRANSACTION_CREATE_EXPENSE
  TRANSACTION_CREATE_TRANSFER
  TRANSACTION_UPDATE
  TRANSACTION_DELETE
  SUBSCRIPTION_CHECKOUT
  SUBSCRIPTION_WEBHOOK
  PAYMENT_SUCCESS
  PAYMENT_FAILED

  // Business — existing
  BUSINESS_COMPANY_CREATE
  BUSINESS_COMPANY_UPDATE
  BUSINESS_MEMBER_INVITE
  BUSINESS_MEMBER_ROLE_UPDATE
  BUSINESS_MEMBER_REVOKE
  BUSINESS_INVOICE_CREATE
  BUSINESS_INVOICE_SENT
  BUSINESS_INVOICE_PAID
  BUSINESS_INVOICE_DELETED
  BUSINESS_CONTACT_CREATE
  BUSINESS_CONTACT_UPDATE
  BUSINESS_CONTACT_DELETE
  BUSINESS_JOURNAL_CREATE
  BUSINESS_JOURNAL_DELETE
  BUSINESS_INVOICE_OVERDUE
  BUSINESS_REPORT_EXPORT

  // Business — Phase 8
  BUSINESS_JOURNAL_SUBMITTED
  BUSINESS_JOURNAL_CHECKED
  BUSINESS_JOURNAL_APPROVED
  BUSINESS_JOURNAL_REJECTED
  BUSINESS_TAX_CONFIG_CREATE
  BUSINESS_TAX_CONFIG_UPDATE
  BUSINESS_TAX_CONFIG_DELETE
  BUSINESS_SUGGESTION_RULE_CREATE
  BUSINESS_SUGGESTION_RULE_UPDATE
  BUSINESS_SUGGESTION_RULE_DELETE
  BUSINESS_ASSET_CREATE
  BUSINESS_ASSET_UPDATE
  BUSINESS_ASSET_DISPOSED
  BUSINESS_ASSET_DEPRECIATION_RUN
  BUSINESS_TRANSACTION_CREATE
  BUSINESS_TRANSACTION_DELETE
}

model PaymentTransaction {
  id               String           @id @default(uuid())
  orderId          String           @unique
  userId           String
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId           String
  plan             SubscriptionPlan @relation(fields: [planId], references: [id])
  amount           Decimal          @db.Decimal(18, 2)
  status           PaymentStatus    @default(PENDING)
  snapToken        String?
  midtransResponse Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([userId, status])
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  EXPIRED
  CANCELLED
}

model Log {
  id          String        @id @default(uuid())
  userId      String?
  user        User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  timestamp   DateTime      @default(now())
  actionType  LogActionType
  entityType  String? // e.g "Account", "Transaction"
  entityId    String?
  description String?
  details     Json?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime      @default(now())
}

model Budget {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  amount      Decimal  @db.Decimal(18, 2)
  year        Int
  month       Int
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, year, month, categoryId])
}

model RecurringTransaction {
  id                   String          @id @default(uuid())
  userId               String
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactionType      TransactionType
  amount               Decimal         @db.Decimal(18, 2)
  description          String?
  categoryId           String?
  category             Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  sourceAccountId      String?
  sourceAccount        Account?        @relation("SourceRecurringTransactions", fields: [sourceAccountId], references: [id], onDelete: SetNull)
  destinationAccountId String?
  destinationAccount   Account?        @relation("DestinationRecurringTransactions", fields: [destinationAccountId], references: [id], onDelete: SetNull)

  interval    RecurringInterval
  startDate   DateTime          @default(now())
  endDate     DateTime?
  nextRunDate DateTime

  lastRunDate DateTime?
  status      RecurringStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions Transaction[]
}

model FinancialGoal {
  id           String       @id @default(uuid())
  userId       String
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  description  String?
  targetAmount Decimal      @db.Decimal(18, 2)
  startDate    DateTime     @default(now())
  targetDate   DateTime?
  status       GoalStatus   @default(ACTIVE)
  priority     Int? // optional ranking (1 = highest priority
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  ledgers      GoalLedger[]
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model GoalLedger {
  id                     String              @id @default(uuid())
  goalId                 String
  goal                   FinancialGoal       @relation(fields: [goalId], references: [id], onDelete: Cascade)
  accountId              String
  account                Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  referenceTransactionId String?
  referenceTransaction   Transaction?        @relation(fields: [referenceTransactionId], references: [id], onDelete: SetNull)
  amount                 Decimal             @db.Decimal(18, 2)
  direction              GoalLedgerDirection
  type                   GoalLedgerType
  note                   String?
  createdAt              DateTime            @default(now())

  @@index([goalId])
  @@index([accountId])
  @@index([referenceTransactionId])
}

enum GoalLedgerDirection {
  INCOMING // Uang dialokasikan ke goal
  OUTGOING // Uang keluar dari goal
}

enum GoalLedgerType {
  ALLOCATE // user menyisihkan uang
  SPEND // Dipakai sesuai tujuan
  RELEASE // Melepas alokasi, misal karena batal mencapai goal
  ADJUST // Penyesuaian manual, misal karena kesalahan input atau perubahan rencana
}

// ─────────────────────────────────────────────
// BUSINESS LAYER
// ─────────────────────────────────────────────

enum CompanyMemberRole {
  OWNER
  ADMIN
  CHECKER
  STAFF
  VIEWER
}

enum CompanyMemberStatus {
  PENDING
  ACTIVE
  REVOKED
}

enum ChartOfAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

// Phase 8: sub-classification for P&L detail
enum ChartOfAccountSubType {
  OPERATING
  NON_OPERATING
  COGS
}

// Phase 8: journal entry approval workflow
enum JournalEntryStatus {
  DRAFT
  PENDING_CHECK
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// Phase 8: supported withholding tax types
enum TaxType {
  PPN
  PPH_21
  PPH_22
  PPH_23
  PPH_4_2
  PPH_15
}

// Phase 8: asset classification
enum AssetType {
  TANGIBLE
  INTANGIBLE
}

// Phase 8: depreciation / amortisation methods (PSAK 16 & PSAK 19)
enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
  DOUBLE_DECLINING
  UNITS_OF_PRODUCTION
}

enum AssetStatus {
  ACTIVE
  DISPOSED
  FULLY_DEPRECIATED
}

model Company {
  id                       String   @id @default(uuid())
  ownerId                  String   @unique
  owner                    User     @relation("CompanyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  name                     String
  npwp                     String?
  logoUrl                  String?
  address                  String?
  phone                    String?
  email                    String?
  taxEnabled               Boolean  @default(true)
  taxRate                  Decimal  @default(11) @db.Decimal(5, 2)
  currency                 String   @default("IDR")
  // Phase 8: approval workflow toggle
  requiresApprovalWorkflow Boolean  @default(false)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  members         CompanyMember[]
  chartOfAccounts ChartOfAccount[]
  contacts        Contact[]
  invoices        Invoice[]
  journalEntries  JournalEntry[]
  bankAccounts    CompanyBankAccount[]
  // Phase 8
  taxConfigs      TaxConfig[]
  taxSuggestionRules TaxSuggestionRule[]
  assets          Asset[]
}

model CompanyMember {
  id        String              @id @default(uuid())
  companyId String
  company   Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  userId    String
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      CompanyMemberRole
  invitedAt DateTime            @default(now())
  joinedAt  DateTime?
  status    CompanyMemberStatus @default(PENDING)

  inviteToken          String?   @unique
  inviteTokenExpiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([companyId, userId])
  @@index([userId, status])
  @@index([inviteToken])
}

model ChartOfAccount {
  id             String                  @id @default(uuid())
  companyId      String
  company        Company                 @relation(fields: [companyId], references: [id], onDelete: Cascade)
  code           String
  name           String
  type           ChartOfAccountType
  // Phase 8: P&L sub-classification (null = not categorised yet)
  subType        ChartOfAccountSubType?
  openingBalance Decimal                 @default(0) @db.Decimal(18, 2)
  isSystem       Boolean                 @default(false)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  journalLines JournalLine[]
  // Phase 8: asset relations (multiple named to distinguish roles)
  assetCoa              Asset[] @relation("AssetCoa")
  accumulatedCoa        Asset[] @relation("AccumulatedCoa")
  depreciationExpenseCoa Asset[] @relation("DepreciationExpenseCoa")
  disposalCoa           Asset[] @relation("DisposalCoa")

  @@unique([companyId, code])
  @@index([companyId, type])
  @@index([companyId, subType])
}

// ─────────────────────────────────────────────
// CONTACT
// ─────────────────────────────────────────────

enum ContactType {
  CUSTOMER
  VENDOR
  EMPLOYEE
}

model Contact {
  id                String      @id @default(uuid())
  companyId         String
  company           Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type              ContactType
  name              String
  email             String?
  phone             String?
  address           String?
  bankName          String?
  bankAccountNumber String?
  bankAccountHolder String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  invoices     Invoice[]
  journalLines JournalLine[]

  @@index([companyId, type])
}

// ─────────────────────────────────────────────
// COMPANY BANK ACCOUNT
// ─────────────────────────────────────────────

model CompanyBankAccount {
  id            String   @id @default(uuid())
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  bankName      String
  accountNumber String
  accountHolder String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  invoices Invoice[]

  @@index([companyId])
}

// ─────────────────────────────────────────────
// INVOICE
// ─────────────────────────────────────────────

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
}

model Invoice {
  id                   String              @id @default(uuid())
  companyId            String
  company              Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contactId            String?
  contact              Contact?            @relation(fields: [contactId], references: [id], onDelete: SetNull)
  invoiceNumber        String
  clientName           String
  clientEmail          String?
  clientAddress        String?
  issueDate            DateTime
  dueDate              DateTime
  status               InvoiceStatus       @default(DRAFT)
  subtotal             Decimal             @db.Decimal(18, 2)
  taxAmount            Decimal             @default(0) @db.Decimal(18, 2)   // PPN dari company default
  withholdingTaxAmount Decimal             @default(0) @db.Decimal(18, 2)   // Pajak dari taxConfig (PPh, dll)
  totalAmount          Decimal             @db.Decimal(18, 2)
  amountPaid           Decimal             @default(0) @db.Decimal(18, 2)
  notes                String?
  sentAt               DateTime?
  paidAt               DateTime?
  paymentDate          DateTime?
  paymentCoaId         String?
  paymentMethod        String?
  paymentReference     String?
  paymentBankAccountId String?
  paymentBankAccount   CompanyBankAccount? @relation(fields: [paymentBankAccountId], references: [id], onDelete: SetNull)
  taxConfigId          String?
  taxConfig            TaxConfig?          @relation(fields: [taxConfigId], references: [id], onDelete: SetNull)
  createdByUserId      String
  createdBy            User                @relation(fields: [createdByUserId], references: [id])
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  items          InvoiceItem[]
  attachments    InvoiceAttachment[]
  journalEntries JournalEntry[]

  @@unique([companyId, invoiceNumber])
  @@index([companyId, status])
}

model InvoiceItem {
  id             String   @id @default(uuid())
  invoiceId      String
  invoice        Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description    String
  quantity       Decimal  @db.Decimal(18, 4)
  unitPrice      Decimal  @db.Decimal(18, 2)
  discountAmount Decimal  @default(0) @db.Decimal(18, 2)
  taxable        Boolean  @default(false)
  taxRate        Decimal  @default(0) @db.Decimal(5, 2)
  taxAmount      Decimal  @default(0) @db.Decimal(18, 2)
  total          Decimal  @db.Decimal(18, 2)

  @@index([invoiceId])
}

model InvoiceAttachment {
  id               String   @id @default(uuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  uploadedByUserId String
  uploadedBy       User     @relation("InvoiceAttachments", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime @default(now())

  @@index([invoiceId])
}

// ─────────────────────────────────────────────
// JOURNAL ENTRY (double-entry, compound)
// ─────────────────────────────────────────────

enum JournalLineType {
  DEBIT
  CREDIT
}

model JournalEntry {
  id                String             @id @default(uuid())
  companyId         String
  company           Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  description       String
  transactionDate   DateTime
  isSystemGenerated Boolean            @default(false)
  invoiceId         String?
  invoice           Invoice?           @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  createdByUserId   String
  createdBy         User               @relation("JournalCreator", fields: [createdByUserId], references: [id])
  createdAt         DateTime           @default(now())

  // Phase 8: approval workflow
  // Default APPROVED so all existing entries remain effective without migration
  status           JournalEntryStatus @default(APPROVED)
  checkerUserId    String?
  checker          User?              @relation("JournalChecker", fields: [checkerUserId], references: [id])
  approverUserId   String?
  approver         User?              @relation("JournalApprover", fields: [approverUserId], references: [id])
  checkedAt        DateTime?
  approvedAt       DateTime?
  rejectedAt       DateTime?
  rejectionNote    String?

  lines            JournalLine[]
  // Phase 8
  attachments      JournalEntryAttachment[]
  assetDepreciation AssetDepreciation?

  @@index([companyId, transactionDate])
  @@index([invoiceId])
  @@index([companyId, status])
}

model JournalLine {
  id             String          @id @default(uuid())
  journalEntryId String
  journalEntry   JournalEntry    @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  coaId          String
  coa            ChartOfAccount  @relation(fields: [coaId], references: [id])
  contactId      String?
  contact        Contact?        @relation(fields: [contactId], references: [id], onDelete: SetNull)
  type           JournalLineType
  amount         Decimal         @db.Decimal(18, 2)
  description    String?

  @@index([journalEntryId])
  @@index([coaId])
}

// Phase 8: Journal entry file attachments
model JournalEntryAttachment {
  id               String       @id @default(uuid())
  journalEntryId   String
  journalEntry     JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)
  companyId        String
  fileName         String
  fileUrl          String
  fileSize         Int
  mimeType         String
  uploadedByUserId String
  uploadedBy       User         @relation("JournalEntryUploads", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime     @default(now())

  @@index([journalEntryId])
  @@index([companyId])
}

// ─────────────────────────────────────────────
// Phase 8: TAX CONFIG (PPh per company)
// ─────────────────────────────────────────────

model TaxConfig {
  id          String   @id @default(uuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  type        TaxType
  name        String   // e.g. "PPh 23 – Jasa Konsultan 2%"
  rate        Decimal  @db.Decimal(7, 4) // e.g. 2.0000
  isActive    Boolean  @default(true)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  suggestionRules TaxSuggestionRule[]
  invoices        Invoice[]

  @@index([companyId, type])
  @@index([companyId, isActive])
}

// Phase 8: custom tax suggestion rules per company
model TaxSuggestionRule {
  id                 String       @id @default(uuid())
  companyId          String
  company            Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  taxConfigId        String
  taxConfig          TaxConfig    @relation(fields: [taxConfigId], references: [id], onDelete: Cascade)
  triggerCoaIds      String[]     // match if debit/credit COA is in this list
  triggerContactType ContactType? // null = any contact type
  triggerKeywords    String[]     // match if description contains any keyword (case-insensitive)
  minAmount          Decimal?     @db.Decimal(18, 2)
  priority           Int          @default(0)
  note               String?
  isActive           Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([companyId])
  @@index([taxConfigId])
}

// ─────────────────────────────────────────────
// Phase 8: ASSET MANAGEMENT (PSAK 16 & PSAK 19)
// ─────────────────────────────────────────────

model Asset {
  id                       String             @id @default(uuid())
  companyId                String
  company                  Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  assetCoaId               String
  assetCoa                 ChartOfAccount     @relation("AssetCoa", fields: [assetCoaId], references: [id])
  accumulatedCoaId         String
  accumulatedCoa           ChartOfAccount     @relation("AccumulatedCoa", fields: [accumulatedCoaId], references: [id])
  depreciationExpenseCoaId String
  depreciationExpenseCoa   ChartOfAccount     @relation("DepreciationExpenseCoa", fields: [depreciationExpenseCoaId], references: [id])
  assetType                AssetType
  name                     String
  code                     String             // e.g. "FA-001"
  acquisitionDate          DateTime
  acquisitionCost          Decimal            @db.Decimal(18, 2)
  residualValue            Decimal            @default(0) @db.Decimal(18, 2)
  usefulLifeMonths         Int
  depreciationMethod       DepreciationMethod
  unitsTotal               Decimal?           @db.Decimal(18, 4) // UoP only
  status                   AssetStatus        @default(ACTIVE)
  disposalDate             DateTime?
  disposalAmount           Decimal?           @db.Decimal(18, 2)
  disposalCoaId            String?
  disposalCoa              ChartOfAccount?    @relation("DisposalCoa", fields: [disposalCoaId], references: [id])
  notes                    String?
  createdByUserId          String
  createdBy                User               @relation(fields: [createdByUserId], references: [id])
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  depreciations AssetDepreciation[]

  @@unique([companyId, code])
  @@index([companyId, status])
  @@index([companyId, assetType])
}

model AssetDepreciation {
  id                      String       @id @default(uuid())
  assetId                 String
  asset                   Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  companyId               String
  periodYear              Int
  periodMonth             Int          // 1–12
  depreciationAmount      Decimal      @db.Decimal(18, 2)
  accumulatedDepreciation Decimal      @db.Decimal(18, 2)
  bookValue               Decimal      @db.Decimal(18, 2)
  unitsProduced           Decimal?     @db.Decimal(18, 4) // UoP only
  journalEntryId          String?      @unique
  journalEntry            JournalEntry? @relation(fields: [journalEntryId], references: [id])
  createdAt               DateTime     @default(now())

  @@unique([assetId, periodYear, periodMonth])
  @@index([companyId, periodYear, periodMonth])
}
